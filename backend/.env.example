# Copy this file to .env and fill in real values. Never commit .env to git.

PROJECT_NAME="BorneoHackwknd API"
VERSION="0.1.0"

# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database connection string
# SQLite (dev):       sqlite+aiosqlite:///./dev.db
# Postgres (prod):    postgresql+asyncpg://user:password@localhost:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./dev.db
DB_ECHO=false

# CORS — comma-separated origins the React Native / web app is served from
ALLOWED_ORIGINS=["http://localhost:19006","http://localhost:8081","http://10.0.2.2:8000"]
