# ─────────────────────────────────────────────────────────────────────────────
# Backend API URL
#
# Leave BLANK to let the app auto-detect per platform:
#   • iOS Simulator    → http://localhost:8000
#   • Android Emulator → http://10.0.2.2:8000
#
# Set to your Mac's LAN IP when testing on a PHYSICAL DEVICE (both iOS & Android):
#   EXPO_PUBLIC_API_URL=http://Your Own Device IP:8000
#
# Find your LAN IP: run ipconfig getifaddr en0 in terminal
# ─────────────────────────────────────────────────────────────────────────────
EXPO_PUBLIC_API_URL= # Enter 

# Google Vision API
EXPO_PUBLIC_VISION_API_KEY= # Enter

# ─────────────────────────────────────────────────────────────────────────────
# Google OAuth Client IDs
# Get these from: https://console.cloud.google.com → APIs & Services → Credentials
#
# EXPO_PUBLIC_GOOGLE_CLIENT_ID       — "Web application" OAuth client (required for Expo Go)
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID   — "iOS" OAuth client (required for native iOS build)
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID — "Android" OAuth client (required for native Android build)
# ─────────────────────────────────────────────────────────────────────────────
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=      # TODO: add iOS client ID from Google Cloud Console
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=  # TODO: add Android client ID from Google Cloud Console